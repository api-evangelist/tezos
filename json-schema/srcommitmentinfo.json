{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SrCommitmentInfo",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "description": "Internal TzKT id.",
      "format": "int64"
    },
    "initiator": {
      "description": "Account that published the commitment first.",
      "oneOf": [
        {
          "$ref": "#/components/schemas/Alias"
        }
      ]
    },
    "inboxLevel": {
      "type": "integer",
      "description": "Inbox level",
      "format": "int32"
    },
    "state": {
      "type": "string",
      "description": "State hash"
    },
    "hash": {
      "type": "string",
      "description": "Commitment hash"
    },
    "ticks": {
      "type": "integer",
      "description": "Number of ticks",
      "format": "int64"
    },
    "firstLevel": {
      "type": "integer",
      "description": "Level of the block where the commitment was first published.",
      "format": "int32"
    },
    "firstTime": {
      "type": "string",
      "description": "Timestamp of the block where the commitment was first published.",
      "format": "date-time"
    }
  }
}